## AffixLibrary.gd
## Autoload — 所有詞綴定義 + lookup
## 資料來源：詞綴速查表

extends Node

var _by_name: Dictionary = {}  # name -> AffixData

func _ready() -> void:
	_load()

# ── Lookup ────────────────────────────────────────
func get_affix(name: String) -> AffixData:
	return _by_name.get(name, null)

func all_affixes() -> Array:
	return _by_name.values()

## 回傳適用於指定 slot key 的所有詞綴
func for_slot(slot_key: String) -> Array:
	var result: Array = []
	for a in _by_name.values():
		if slot_key in a.applicable_slots:
			result.append(a)
	return result

# ── 計算裝備加成 ──────────────────────────────────
## 傳入 item_library 和 equipment，回傳加總後的 stat bonuses
## 格式：{ stat_key: total_value, ... }
func calc_bonuses(item_library: Array, equipment: Dictionary) -> Dictionary:
	var bonuses: Dictionary = {}
	for slot in equipment:
		var item_id: String = equipment[slot]
		if item_id == "": continue
		var item := _find_item_by_id(item_library, item_id)
		if item.is_empty(): continue
		for mod in item.get("mods", []):
			var affix := get_affix(mod.get("type", ""))
			if affix == null: continue
			var val: int = mod.get("value", 0)
			for sk in affix.stat_keys:
				bonuses[sk] = bonuses.get(sk, 0) + val
	return bonuses

func _find_item_by_id(library: Array, id: String) -> Dictionary:
	for item in library:
		if item.get("id", "") == id:
			return item
	return {}

# ── 資料 ──────────────────────────────────────────
func _add(name: String, slots: Array, stat_keys: Array, tiers: Array) -> void:
	_by_name[name] = AffixData.new(name, slots, stat_keys, tiers)

func _t(cost: int, value: int, effect: String) -> Dictionary:
	return { "cost": cost, "value": value, "effect": effect }

